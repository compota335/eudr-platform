# --- Application ---
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
APP_BASE_URL=http://localhost:8000

# --- Database ---
# Development defaults to a local SQLite file when DATABASE_URL is unset.
# Production example (PostgreSQL):
# DATABASE_URL=postgresql+psycopg://eudr:eudr@localhost:5432/eudr
DATABASE_URL=

# --- Deforestation data providers ---
# Open Foris Whisp API (FAO) - plot statistics for EUDR convergence of evidence.
# Register for a free key at https://whisp.openforis.org/register and paste it
# below. Without it, plot-checker and assess fail loud (HTTP 503) by design.
# See docs/whisp-integration.md.
WHISP_API_URL=https://whisp.openforis.org/api
WHISP_API_KEY=

# Global Forest Watch Data API (fallback / secondary zonal statistics).
GFW_API_URL=https://data-api.globalforestwatch.org
GFW_API_KEY=

# --- Email capture (PDF gating) ---
# Transactional email provider is wired in a later phase; left blank for now.
EMAIL_PROVIDER=
EMAIL_FROM=

# --- Evidence store ---
EVIDENCE_STORE_PATH=./evidence_store
